rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // User entity validation
    function isValidUser(data) {
      return data.keys().hasAll(['spreadsheetId', 'updatedAt']) &&
             data.keys().size() == 2 &&
             data.spreadsheetId is string &&
             data.spreadsheetId.size() <= 128 &&
             data.updatedAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().updatedAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && 
                    incoming().updatedAt == request.time &&
                    incoming().diff(resource.data).affectedKeys().hasOnly(['spreadsheetId', 'updatedAt']);
    }
  }
}
